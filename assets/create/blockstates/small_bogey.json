{
  "multipart": [
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_shafts", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_frame", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_wheel", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_shafts" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_frame" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_wheel" }
    }
  ]
}
