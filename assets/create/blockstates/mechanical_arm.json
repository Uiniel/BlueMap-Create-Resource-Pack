{
  "multipart": [
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "create:block/mechanical_arm/block" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/base_transformed" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/claw_base_transformed" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "create:block/mechanical_arm/cog" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/lower_body_transformed" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/upper_body_transformed" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/lower_claw_grip_transformed" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/upper_claw_grip_transformed" }
    },
    {
      "when": { "ceiling": "false" },
      "apply": { "model": "create:block/mechanical_arm/block" }
    },

    {
