    {
      "when": { "ceiling": "true" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/claw_base_transformed", "x": 180 }
    },
    {
      "when": { "ceiling": "true" },
      "apply": { "model": "create:block/mechanical_arm/cog", "x": 180 }
    },
    {
      "when": { "ceiling": "true" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/lower_body_transformed", "x": 180 }
    },
    {
      "when": { "ceiling": "true" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/upper_body_transformed", "x": 180 }
    },
    {
      "when": { "ceiling": "true" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/lower_claw_grip_transformed", "x": 180 }
    },
    {
      "when": { "ceiling": "true" },
      "apply": { "model": "bluemap_create:block/mechanical_arm/upper_claw_grip_transformed", "x": 180 }
    },
    {
      "when": { "ceiling": "true" },
      "apply": { "model": "create:block/mechanical_arm/block", "x": 180 }
