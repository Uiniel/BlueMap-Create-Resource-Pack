{
  "multipart": [
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_shafts", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_shafts_large", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_belt", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_piston", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_wheel", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "x" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_wheel_pin", "y": 90 }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_shafts" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_shafts_large" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_belt" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_piston" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_wheel" }
    },
    {
      "when": {
        "AND": [
          { "axis": "z" }
        ]
      },
      "apply": { "model": "bluemap_create:block/track/bogey/bogey_drive_wheel_pin" }
    }
  ]
}
